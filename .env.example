# ─── Email (SMTP) Configuration ───────────────────────────────────────────────
# Gmail: use an App Password (not your regular password)
# Generate at: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password-here

# Sender display name
EMAIL_FROM_NAME=Prithvi Pulse – Environment Club
EMAIL_FROM_ADDRESS=your-email@gmail.com

# Admin email for carbon-copy / internal logs
EVENT_ADMIN_EMAIL=admin@krmangalam.edu.in

# ─── Supabase (Service Role Key – never expose in frontend) ───────────────────
# Find at: Supabase Dashboard → Project Settings → API → service_role key
SUPABASE_URL=https://ikfxcdpyspwpbhsocjno.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
# Set to your production domain when deployed (e.g. https://your-site.com)
ALLOWED_ORIGIN=http://127.0.0.1:5500

# ─── Admin Secret (simple token to protect email API endpoints) ───────────────
ADMIN_SECRET=change-this-to-a-long-random-string
